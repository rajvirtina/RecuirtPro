# Files and directories to exclude from production deployment

# Development and testing
*.test.ts
*.test.js
*.spec.ts
*.spec.js
test-*.js
__tests__/
__mocks__/
.vscode/
.idea/

# Documentation (optional - remove if you don't want docs in prod)
ARCHITECTURE.md
END_TO_END_TEST_PLAN.md
FEATURES_IMPLEMENTATION.md
QUICK_FIX.md
SUPER_ADMIN_GUIDE.md
USER_DOCUMENTATION.md
BUGFIX_TECHNICAL_DOCUMENTATION.md
QUICK_SETUP_GUIDE.md
COMPANY_SLUG_GUIDE.md

# Test scripts
test-admin-api.js
test-hr-quick.js
test-hr-registration-flow.js
test-job-creation.js
test-runner.js

# Environment files (configure separately on server)
.env
.env.local
.env.development
.env.test

# Dependencies (will be installed on server)
node_modules/
package-lock.json
yarn.lock

# Build artifacts (will be regenerated)
dist/
build/
.next/
out/

# Logs and temp files
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.DS_Store
Thumbs.db

# Development files
*.swp
*.swo
*~
.cache/

# Git
.git/
.gitignore
.gitattributes

# Docker (if not using docker in prod)
docker-compose.yml
Dockerfile.dev

# Uploads (will be stored on server/cloud)
uploads/resumes/*.pdf
uploads/resumes/*.doc
uploads/resumes/*.docx

# Keep only README for quick reference
# README.md (keep this)
# DEPLOYMENT.md (keep this)
# PRIVACY_POLICY.md (keep if legally required)
