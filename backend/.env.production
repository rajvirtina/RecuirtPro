# ═══════════════════════════════════════════════════════════════
# RecuirtPro Backend — PRODUCTION Environment Configuration
# ═══════════════════════════════════════════════════════════════
# COPY this file to .env and fill in ALL values marked [REQUIRED]

# ── Core ──────────────────────────────────────────────────────
NODE_ENV=production
PORT=5001
SERVER_URL=https://api.recruitpro.yourdomain.com

# ── MongoDB Atlas ─────────────────────────────────────────────
# [REQUIRED] Use MongoDB Atlas or AWS DocumentDB for production
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/recruitpro?retryWrites=true&w=majority

# ── JWT — MUST be unique, random, 64+ chars ──────────────────
# [REQUIRED] Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=
JWT_EXPIRE=1d
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRE=7d

# ── Encryption — MUST be exactly 32 chars ─────────────────────
# [REQUIRED] Generate with: node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
ENCRYPTION_KEY=

# ── Session Secret ────────────────────────────────────────────
# [REQUIRED]
SESSION_SECRET=

# ── CORS — your Hostinger frontend domain ─────────────────────
CORS_ORIGIN=https://recruitpro.yourdomain.com,https://www.recruitpro.yourdomain.com

# ── Frontend URL (for email links, redirects) ─────────────────
FRONTEND_URL=https://recruitpro.yourdomain.com

# ── Redis (ElastiCache or Redis Cloud) ────────────────────────
# [REQUIRED] for Bull job queues (email, cross-portal)
REDIS_HOST=your-redis-host.cache.amazonaws.com
REDIS_PORT=6379
REDIS_PASSWORD=

# ── Email (SMTP) ─────────────────────────────────────────────
SKIP_EMAIL=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-production-email@gmail.com
SMTP_PASSWORD=your-gmail-app-password
EMAIL_FROM=noreply@recruitpro.yourdomain.com
EMAIL_FROM_NAME=RecuirtPro

# ── AWS S3 (Resume/File Storage) ─────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
AWS_S3_BUCKET=recruitpro-uploads

# ── File Upload ───────────────────────────────────────────────
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads

# ═══════════════════════════════════════════════════════════════
# SOURCING INTEGRATIONS — LinkedIn, Naukri, GitHub
# ═══════════════════════════════════════════════════════════════

# ── LinkedIn OAuth2 ───────────────────────────────────────────
# Get from: https://www.linkedin.com/developers/apps
# 1. Create app → Products → Sign In with LinkedIn using OpenID Connect
# 2. Auth tab → Redirect URL: https://api.recruitpro.yourdomain.com/api/v1/sourcing/oauth/linkedin/callback
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=https://api.recruitpro.yourdomain.com/api/v1/sourcing/oauth/linkedin/callback
ENABLE_LINKEDIN_INTEGRATION=true

# ── Naukri RMS API ────────────────────────────────────────────
# Get from: Naukri Recruiter Dashboard → Settings → API/Integrations
NAUKRI_API_KEY=
NAUKRI_API_SECRET=
NAUKRI_BASE_URL=https://api.naukri.com
ENABLE_NAUKRI_INTEGRATION=true

# ── GitHub OAuth2 ─────────────────────────────────────────────
# Get from: https://github.com/settings/developers → OAuth Apps → New
# Callback URL: https://api.recruitpro.yourdomain.com/api/v1/sourcing/oauth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=https://api.recruitpro.yourdomain.com/api/v1/sourcing/oauth/github/callback
# Optional: Personal access token for higher rate limits (Settings → Developer settings → Tokens)
GITHUB_TOKEN=

# ═══════════════════════════════════════════════════════════════
# LLM SERVICE — AI-powered features
# ═══════════════════════════════════════════════════════════════

# URL of the LLM microservice (same EC2 or separate)
LLM_SERVICE_URL=http://localhost:8001
LLM_API_SECRET_KEY=

# ═══════════════════════════════════════════════════════════════
# CALENDAR INTEGRATIONS (Optional)
# ═══════════════════════════════════════════════════════════════

# Microsoft Graph API
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_TENANT_ID=common
MS_REDIRECT_URI=https://api.recruitpro.yourdomain.com/api/auth/microsoft/callback

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://api.recruitpro.yourdomain.com/api/auth/google/callback

# ═══════════════════════════════════════════════════════════════
# FEATURE FLAGS
# ═══════════════════════════════════════════════════════════════
ENABLE_PROCTORING=true
ENABLE_MFA=true
ENABLE_EMAIL_VERIFICATION=true

# ── Rate Limiting ─────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL=info
LOG_FILE_PATH=./logs

# ── Data Retention (days) ─────────────────────────────────────
RESUME_RETENTION_DAYS=365
AUDIT_LOG_RETENTION_DAYS=730
APPLICATION_RETENTION_DAYS=180

# ── Company ───────────────────────────────────────────────────
COMPANY_NAME=RecuirtPro
SUPPORT_EMAIL=support@recruitpro.yourdomain.com
