# ── CORS — your Hostinger frontend domain ─────────────────────
CORS_ORIGIN=https://hiring.ambiquest.com,https://www.hiring.ambiquest.com,http://localhost:3000

# ── Frontend URL (for email links, redirects) ─────────────────
FRONTEND_URL=https://hiring.ambiquest.com

# ── Redis (ElastiCache or Redis Cloud) ────────────────────────
# [REQUIRED] for Bull job queues (email, cross-portal)
# [OPTIONAL] Redis — Hostinger shared hosting blocks external Redis connections
# Leave REDIS_HOST empty to disable queues (emails send synchronously instead)
REDIS_HOST=
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TLS=false

# ── Email (SMTP) ─────────────────────────────────────────────
SKIP_EMAIL=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=rk.solutions0904@gmail.com
SMTP_PASSWORD=pmbu rzul oyxm byic
EMAIL_FROM=noreply@recruitpro.ambiquest.com
EMAIL_FROM_NAME=Ambiquest RecuirtPro

# ── AWS S3 (Resume/File Storage) ─────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
AWS_S3_BUCKET=recruitpro-uploads

# ── File Upload ───────────────────────────────────────────────
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads

# ═══════════════════════════════════════════════════════════════
# SOURCING INTEGRATIONS — LinkedIn, Naukri, GitHub
# ═══════════════════════════════════════════════════════════════

# ── LinkedIn OAuth2 ───────────────────────────────────────────
# Get from: https://www.linkedin.com/developers/apps
# 1. Create app → Products → Sign In with LinkedIn using OpenID Connect
# 2. Auth tab → Redirect URL: https://api.recruitpro.yourdomain.com/api/v1/sourcing/oauth/linkedin/callback
LINKEDIN_CLIENT_ID=86ofxlq8mnwsbw
LINKEDIN_CLIENT_SECRET=WPL_AP1.la474riCpP4eSzCn.HrU7Gg==
LINKEDIN_REDIRECT_URI=https://api.recruitpro.yourdomain.com/api/v1/sourcing/oauth/linkedin/callback
ENABLE_LINKEDIN_INTEGRATION=true

# ── Naukri RMS API ────────────────────────────────────────────
# Get from: Naukri Recruiter Dashboard → Settings → API/Integrations
NAUKRI_API_KEY=
NAUKRI_API_SECRET=
NAUKRI_BASE_URL=https://api.naukri.com
ENABLE_NAUKRI_INTEGRATION=true

# ── GitHub OAuth2 ─────────────────────────────────────────────
# Get from: https://github.com/settings/developers → OAuth Apps → New
