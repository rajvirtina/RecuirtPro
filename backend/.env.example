# Environment Configuration
NODE_ENV=development
PORT=5000

# Database
MONGODB_URI=mongodb://localhost:27017/recruitpro

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=your-refresh-token-secret-change-in-production
JWT_REFRESH_EXPIRE=30d

# CORS
CORS_ORIGIN=http://localhost:3000

# Email Configuration (SendGrid/SES/SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@recruitpro.com
EMAIL_FROM_NAME=RecuirtPro

# SMS Configuration
SMS_API_KEY=your-sms-api-key
SMS_SENDER_ID=RECRUIT
SMS_PROVIDER=twilio

# File Storage (AWS S3)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=recruitpro-uploads
MAX_FILE_SIZE=10485760

# Redis (for queues and caching)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Microsoft Graph API
MS_CLIENT_ID=your-microsoft-client-id
MS_CLIENT_SECRET=your-microsoft-client-secret
MS_TENANT_ID=common
MS_REDIRECT_URI=http://localhost:5000/api/auth/microsoft/callback

# Google OAuth & Calendar
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:5000/api/auth/google/callback

# Zoho
ZOHO_CLIENT_ID=your-zoho-client-id
ZOHO_CLIENT_SECRET=your-zoho-client-secret
ZOHO_REDIRECT_URI=http://localhost:5000/api/auth/zoho/callback

# Naukri Integration
NAUKRI_API_KEY=your-naukri-api-key
NAUKRI_API_SECRET=your-naukri-secret
NAUKRI_BASE_URL=https://api.naukri.com

# LinkedIn (Optional)
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret

# Feature Flags
ENABLE_PROCTORING=true
ENABLE_NAUKRI_INTEGRATION=true
ENABLE_LINKEDIN_INTEGRATION=false
ENABLE_MFA=true
ENABLE_EMAIL_VERIFICATION=true

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=debug
LOG_FILE_PATH=./logs

# Session
SESSION_SECRET=your-session-secret-change-in-production

# Frontend URL
FRONTEND_URL=http://localhost:3000

# Encryption
ENCRYPTION_KEY=your-32-char-encryption-key-here

# Data Retention (in days)
RESUME_RETENTION_DAYS=365
AUDIT_LOG_RETENTION_DAYS=730
APPLICATION_RETENTION_DAYS=180
